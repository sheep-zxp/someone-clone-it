ANTHROPIC_AUTH_TOKEN=your_token_here
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M2.7-highspeed
ANTHROPIC_DEFAULT_OPUS_MODEL=MiniMax-M2.7-highspeed
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.7-highspeed
ANTHROPIC_MODEL=MiniMax-M2.7-highspeed
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
DISABLE_TELEMETRY=1

# For claude_rename launcher profile:
# anthropic-compatible | openrouter | openai | google
HAHA_API_PROVIDER=anthropic-compatible

# OpenRouter (Anthropic-compatible endpoint)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1/anthropic
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# OpenAI (native OpenAI provider)
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI-through-Anthropic-compatible gateway (optional legacy bridge)
OPENAI_ANTHROPIC_BASE_URL=

GOOGLE_API_KEY=
GOOGLE_MODEL=
GOOGLE_ANTHROPIC_BASE_URL=
